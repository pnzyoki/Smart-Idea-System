# ==========================================================================
# SMART IDEA SYSTEM - CONFIGURATION ENV
# ==========================================================================
# Configure your live Supabase database and authentication project below.
# If these options are left blank or unchanged, the application will automatically 
# operate in local Sandbox mode using browser localStorage.

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Set your actual OpenAI API Key below to enable dynamic AI critiques and groupings.
VITE_OPENAI_API_KEY=YOUR_OPENAI_API_KEY
